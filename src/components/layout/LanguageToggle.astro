---
import type { Lang } from '../../i18n/ui';
import { getAlternatePath } from '../../i18n/ui';

interface Props {
  lang: Lang;
  alternatePath?: string;
}

const { lang, alternatePath = '/' } = Astro.props;
const altLang = lang === 'fr' ? 'en' : 'fr';
const altHref = getAlternatePath(lang, alternatePath);
---

<div class="lang-toggle" aria-label="Language selector">
  <span class:list={['lang-opt', { active: lang === 'fr' }]}>
    {lang === 'fr' ? 'FR' : <a href={`/fr${alternatePath}`}>FR</a>}
  </span>
  <span class="lang-sep" aria-hidden="true">/</span>
  <span class:list={['lang-opt', { active: lang === 'en' }]}>
    {lang === 'en' ? 'EN' : <a href={altHref}>EN</a>}
  </span>
</div>

<style>
  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
  }

  .lang-sep {
    color: var(--color-border);
    font-weight: 300;
  }

  .lang-opt {
    color: var(--color-text-muted);
    transition: color var(--duration-fast) ease;
  }

  .lang-opt.active {
    color: var(--color-gold);
  }

  .lang-opt a {
    color: var(--color-text-muted);
    transition: color var(--duration-fast) ease;
  }

  .lang-opt a:hover {
    color: var(--color-text);
  }
</style>
