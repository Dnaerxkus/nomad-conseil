---
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/ui';
import LanguageToggle from './LanguageToggle.astro';
import { url } from '../../utils/asset';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const base = `/${lang}`;
const current = Astro.url.pathname;

const navItems = [
  { key: 'nav.services',   href: url(`${base}/activites`) },
  { key: 'nav.references', href: url(`${base}/references`) },
  { key: 'nav.clients',    href: url(`${base}/clients`) },
  { key: 'nav.team',       href: url(`${base}/equipe`) },
  { key: 'nav.contact',    href: url(`${base}/contact`) },
] as const;

const navItemsEn = [
  { key: 'nav.services',   href: url(`${base}/services`) },
  { key: 'nav.references', href: url(`${base}/references`) },
  { key: 'nav.clients',    href: url(`${base}/clients`) },
  { key: 'nav.team',       href: url(`${base}/team`) },
  { key: 'nav.contact',    href: url(`${base}/contact`) },
] as const;

const items = lang === 'fr' ? navItems : navItemsEn;
---

<header class="site-header" id="site-header">
  <div class="header-inner page-wrap">
    <!-- Logo -->
    <a href={url(`/${lang}/`)} class="logo-link" aria-label="Nomad Conseil — Accueil">
      <svg viewBox="0 0 280 48" fill="none" class="logo-svg" aria-hidden="true">
        <defs>
          <clipPath id="h-right-clip"><rect x="39" y="0" width="44" height="48"/></clipPath>
          <clipPath id="h-left-clip"><rect x="0" y="0" width="39" height="48"/></clipPath>
        </defs>
        <ellipse cx="22" cy="24" rx="20" ry="13" stroke="var(--color-gold)" stroke-width="1.75"/>
        <ellipse cx="56" cy="24" rx="20" ry="13" stroke="var(--color-gold)" stroke-width="1.75" clip-path="url(#h-right-clip)"/>
        <ellipse cx="56" cy="24" rx="20" ry="13" stroke="var(--color-gold)" stroke-width="1.75" clip-path="url(#h-left-clip)" opacity="0.28"/>
        <line x1="90" y1="10" x2="90" y2="38" stroke="var(--color-gold)" stroke-width="0.6" opacity="0.45"/>
        <text x="102" y="22" font-family="'Cormorant','Cormorant Garamond',Georgia,serif" font-size="17" font-weight="400" letter-spacing="5" fill="var(--color-text)">NOMAD</text>
        <text x="102" y="40" font-family="'Cormorant','Cormorant Garamond',Georgia,serif" font-size="17" font-weight="300" letter-spacing="5" fill="var(--color-text-muted)">CONSEIL</text>
      </svg>
    </a>

    <!-- Desktop nav -->
    <nav class="nav-desktop" aria-label="Navigation principale">
      <ul>
        {items.map(({ key, href }) => (
          <li>
            <a
              href={href}
              class:list={['nav-link', { active: current.startsWith(href) }]}
              aria-current={current.startsWith(href) ? 'page' : undefined}
            >
              {t(lang, key)}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Right cluster: lang toggle + mobile menu trigger -->
    <div class="header-right">
      <LanguageToggle lang={lang} />
      <button class="menu-btn" id="menu-btn" aria-label="Menu" aria-expanded="false" aria-controls="mobile-nav">
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <nav class="nav-mobile" id="mobile-nav" aria-label="Navigation mobile" hidden>
    <ul>
      {items.map(({ key, href }) => (
        <li>
          <a href={href} class:list={['nav-link-mobile', { active: current.startsWith(href) }]}>
            {t(lang, key)}
          </a>
        </li>
      ))}
    </ul>
    <div class="mobile-lang">
      <LanguageToggle lang={lang} />
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const nav = document.getElementById('mobile-nav');
  btn?.addEventListener('click', () => {
    const open = nav?.hasAttribute('hidden') === false;
    nav?.toggleAttribute('hidden', !open ? true : false);
    btn.setAttribute('aria-expanded', open ? 'false' : 'true');
    btn.classList.toggle('open', !open);
    document.body.style.overflow = open ? '' : 'hidden';
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: rgba(242, 237, 230, 0.92);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
    gap: var(--sp-4);
  }

  .logo-link {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .logo-svg {
    height: 36px;
    width: auto;
  }

  /* Desktop nav */
  .nav-desktop ul {
    display: flex;
    align-items: center;
    gap: var(--sp-6);
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
    transition: color var(--duration-fast) ease;
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-gold);
    transition: width var(--duration-base) var(--ease-out);
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-text);
  }

  .nav-link.active::after,
  .nav-link:hover::after {
    width: 100%;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }

  /* Menu button */
  .menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
  }

  .bar {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--color-text);
    transition: transform var(--duration-base) var(--ease-out), opacity var(--duration-base) ease;
    transform-origin: center;
  }

  .menu-btn.open .bar:first-child { transform: translateY(6px) rotate(45deg); }
  .menu-btn.open .bar:last-child  { transform: translateY(-6px) rotate(-45deg); }

  /* Mobile nav */
  .nav-mobile {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    padding: var(--sp-6) var(--page-padding) var(--sp-8);
  }

  .nav-mobile ul {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    margin-bottom: var(--sp-6);
  }

  .nav-link-mobile {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 300;
    color: var(--color-text);
    transition: color var(--duration-fast) ease;
  }

  .nav-link-mobile:hover,
  .nav-link-mobile.active {
    color: var(--color-gold);
  }

  .mobile-lang { padding-top: var(--sp-2); }

  @media (max-width: 860px) {
    .nav-desktop { display: none; }
    .menu-btn { display: flex; }
  }
</style>
