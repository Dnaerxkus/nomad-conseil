---
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/ui';
import LanguageToggle from './LanguageToggle.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const base = `/${lang}`;

const navItems = lang === 'fr'
  ? [
      { key: 'nav.services',   href: `${base}/activites` },
      { key: 'nav.references', href: `${base}/references` },
      { key: 'nav.clients',    href: `${base}/clients` },
      { key: 'nav.team',       href: `${base}/equipe` },
      { key: 'nav.news',       href: `${base}/actualites` },
      { key: 'nav.contact',    href: `${base}/contact` },
    ]
  : [
      { key: 'nav.services',   href: `${base}/services` },
      { key: 'nav.references', href: `${base}/references` },
      { key: 'nav.clients',    href: `${base}/clients` },
      { key: 'nav.team',       href: `${base}/team` },
      { key: 'nav.news',       href: `${base}/news` },
      { key: 'nav.contact',    href: `${base}/contact` },
    ];
---

<footer class="site-footer dark-band">
  <div class="footer-inner page-wrap">

    <!-- Brand column -->
    <div class="footer-brand">
      <a href={`/${lang}/`} class="footer-logo" aria-label="Nomad Conseil">
        <svg viewBox="0 0 280 48" fill="none" class="footer-logo-svg" aria-hidden="true">
          <defs>
            <clipPath id="f-right-clip"><rect x="39" y="0" width="44" height="48"/></clipPath>
            <clipPath id="f-left-clip"><rect x="0" y="0" width="39" height="48"/></clipPath>
          </defs>
          <ellipse cx="22" cy="24" rx="20" ry="13" stroke="var(--color-gold)" stroke-width="1.75"/>
          <ellipse cx="56" cy="24" rx="20" ry="13" stroke="var(--color-gold)" stroke-width="1.75" clip-path="url(#f-right-clip)"/>
          <ellipse cx="56" cy="24" rx="20" ry="13" stroke="var(--color-gold)" stroke-width="1.75" clip-path="url(#f-left-clip)" opacity="0.28"/>
          <line x1="90" y1="10" x2="90" y2="38" stroke="var(--color-gold)" stroke-width="0.6" opacity="0.45"/>
          <text x="102" y="22" font-family="'Cormorant','Cormorant Garamond',Georgia,serif" font-size="17" font-weight="400" letter-spacing="5" fill="#f2ede6">NOMAD</text>
          <text x="102" y="40" font-family="'Cormorant','Cormorant Garamond',Georgia,serif" font-size="17" font-weight="300" letter-spacing="5" fill="#8a8780">CONSEIL</text>
        </svg>
      </a>
      <p class="footer-tagline">{t(lang, 'footer.tagline')}</p>
      <p class="footer-location">{t(lang, 'footer.location')}</p>
    </div>

    <!-- Nav column -->
    <nav class="footer-nav" aria-label="Footer navigation">
      <ul>
        {navItems.map(({ key, href }) => (
          <li>
            <a href={href} class="footer-nav-link">{t(lang, key)}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Meta column -->
    <div class="footer-meta">
      <LanguageToggle lang={lang} />
      <a href={`/${lang}/contact`} class="footer-email">contact@nomad-conseil.fr</a>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom page-wrap">
    <span class="mono footer-copy">{t(lang, 'footer.copy')}</span>
    <span class="mono footer-copy">Réalisé avec soin</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-gold);
    padding-top: var(--sp-12);
    padding-bottom: var(--sp-6);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: var(--sp-8);
    padding-bottom: var(--sp-8);
    border-bottom: 1px solid var(--color-border-dark);
  }

  .footer-logo { display: inline-flex; }
  .footer-logo-svg { height: 30px; width: auto; }

  .footer-tagline {
    margin-top: var(--sp-3);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-ash);
    max-width: none;
  }

  .footer-location {
    margin-top: var(--sp-1);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-ash);
    max-width: none;
  }

  .footer-nav ul {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .footer-nav-link {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-ash);
    transition: color var(--duration-fast) ease;
  }

  .footer-nav-link:hover { color: var(--color-chalk); }

  .footer-meta {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    align-items: flex-start;
  }

  .footer-email {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-gold);
    transition: opacity var(--duration-fast) ease;
  }

  .footer-email:hover { opacity: 0.75; }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--sp-4);
    font-size: 10px;
    letter-spacing: 0.08em;
  }

  .footer-copy { color: var(--color-ash); }

  @media (max-width: 700px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: var(--sp-6);
    }
  }
</style>
