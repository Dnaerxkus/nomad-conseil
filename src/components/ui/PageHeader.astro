---
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
  label: string;
  title: string;
  sub?: string;
  mono?: boolean;
}

const { label, title, sub, mono = false } = Astro.props;
---

<div class="page-header">
  <div class="page-wrap">
    <span class="section-label hero-line">{label}</span>
    <h1 class="page-title hero-line">{title}</h1>
    {sub && (
      <p class:list={['page-sub hero-line', { mono: mono }]}>{sub}</p>
    )}
    <div class="header-rule hero-accent-line"></div>
  </div>
</div>

<style>
  .page-header {
    padding-top: var(--sp-12);
    padding-bottom: var(--sp-8);
    border-bottom: 1px solid var(--color-border);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 300;
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    margin-bottom: var(--sp-2);
  }

  .page-sub {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    font-weight: 300;
    max-width: none;
    margin-top: var(--sp-2);
  }

  .page-sub.mono {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .header-rule {
    width: 48px;
    height: 1px;
    background: var(--color-gold);
    margin-top: var(--sp-4);
    transform-origin: left;
  }
</style>
