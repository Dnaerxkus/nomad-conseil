---
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const contactHref = lang === 'fr' ? '/fr/contact' : '/en/contact';
---

<section class="cta-band dark-band">
  <div class="page-wrap cta-inner reveal">
    <h2 class="cta-title">{t(lang, 'cta.contact')}</h2>
    <a href={contactHref} class="cta-btn">{t(lang, 'cta.contact.btn')} →</a>
  </div>
</section>

<style>
  .cta-band {
    padding-block: var(--sp-16);
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-8);
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl));
    font-weight: 300;
    font-style: italic;
    color: var(--color-stone);
    line-height: var(--leading-tight);
    max-width: 22ch;
  }

  .cta-btn {
    flex-shrink: 0;
    display: inline-block;
    border: 1px solid var(--color-gold);
    color: var(--color-gold);
    padding: var(--sp-2) var(--sp-6);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    transition:
      background var(--duration-base) ease,
      color var(--duration-base) ease;
  }

  .cta-btn:hover {
    background: var(--color-gold);
    color: var(--color-void);
  }

  @media (max-width: 640px) {
    .cta-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
