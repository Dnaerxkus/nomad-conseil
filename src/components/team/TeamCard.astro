---
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;

const bio = lang === 'fr'
  ? 'Mathieu [Nom] fonde Nomad Conseil après plus de vingt ans d\'expérience dans la maîtrise d\'ouvrage de grands projets immobiliers tertiaires. Directeur de programme pour AXA, Gecina et Generali, il accompagne aujourd\'hui investisseurs institutionnels et promoteurs à chaque phase de leur projet — de la programmation à la livraison.'
  : 'Mathieu [Name] founded Nomad Conseil after over twenty years leading complex commercial real estate projects for major institutional investors. Having served as Programme Director for AXA, Gecina and Generali, he now supports investors, developers and occupiers across every stage of their projects — from brief to handover.';

const tags = ['AMO', 'MOD', 'Due Diligence', lang === 'fr' ? '+30 ans' : '30+ years'];
---

<section class="team-section section">
  <div class="page-wrap team-grid">
    <!-- Photo column -->
    <div class="team-photo reveal">
      <div class="photo-placeholder" aria-label={lang === 'fr' ? 'Photo de Mathieu' : 'Photo of Mathieu'}>
        <!-- Warm linen gradient with subtle grid overlay -->
        <svg class="photo-grid" aria-hidden="true" viewBox="0 0 400 480" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="grid" width="24" height="24" patternUnits="userSpaceOnUse">
              <path d="M 24 0 L 0 0 0 24" fill="none" stroke="rgba(184,154,106,0.12)" stroke-width="0.5"/>
            </pattern>
          </defs>
          <rect width="400" height="480" fill="url(#grid)"/>
        </svg>
        <div class="photo-monogram" aria-hidden="true">M</div>
        <p class="photo-caption mono">{lang === 'fr' ? 'Photo à venir' : 'Photo coming soon'}</p>
      </div>
    </div>

    <!-- Text column -->
    <div class="team-text reveal">
      <div class="team-meta">
        <span class="section-label">{t(lang, 'section.team')}</span>
        <h2 class="team-name">Mathieu</h2>
        <p class="team-title">{t(lang, 'team.founder')}</p>
      </div>

      <p class="team-bio">{bio}</p>

      <div class="team-tags" role="list" aria-label={lang === 'fr' ? 'Domaines d\'expertise' : 'Areas of expertise'}>
        {tags.map(tag => (
          <span class="tag" role="listitem">{tag}</span>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Quote band -->
<div class="team-quote dark-band">
  <div class="page-wrap">
    <blockquote class="quote-text reveal">
      <p>
        {lang === 'fr'
          ? '«\u202fLa qualité d\'un projet tient à l\'exigence de celui qui l\'accompagne.\u202f»'
          : '«\u202fThe quality of a project rests on the rigour of those who guide it.\u202f»'}
      </p>
    </blockquote>
  </div>
</div>

<style>
  .team-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-16);
    align-items: start;
  }

  /* Photo */
  .photo-placeholder {
    position: relative;
    aspect-ratio: 4 / 5;
    background: linear-gradient(
      145deg,
      #ede8df 0%,
      #ddd5c8 30%,
      #cdc4b5 60%,
      #bfb6a6 100%
    );
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--sp-4);
  }

  .photo-grid {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .photo-monogram {
    position: relative;
    z-index: 1;
    font-family: var(--font-display);
    font-size: clamp(6rem, 15vw, 12rem);
    font-weight: 300;
    color: rgba(15, 15, 13, 0.12);
    line-height: 1;
    user-select: none;
  }

  .photo-caption {
    position: relative;
    z-index: 1;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: rgba(15, 15, 13, 0.35);
    max-width: none;
    margin: 0;
  }

  /* Text */
  .team-text {
    display: flex;
    flex-direction: column;
    gap: var(--sp-8);
    padding-top: var(--sp-4);
  }

  .team-meta { display: flex; flex-direction: column; gap: var(--sp-2); }

  .team-name {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 300;
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
    color: var(--color-void);
  }

  .team-title {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-gold);
    max-width: none;
    margin: 0;
  }

  .team-bio {
    font-size: var(--text-lg);
    font-weight: 300;
    line-height: var(--leading-loose);
    color: var(--color-text-muted);
    max-width: 48ch;
  }

  .team-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  /* Quote band */
  .team-quote {
    padding-block: var(--sp-12);
    margin-top: var(--sp-12);
  }

  .quote-text p {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    font-weight: 300;
    font-style: italic;
    color: var(--color-chalk);
    line-height: var(--leading-tight);
    letter-spacing: -0.01em;
    max-width: 26ch;
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal { transition: none !important; animation: none !important; opacity: 1 !important; transform: none !important; }
  }

  @media (max-width: 860px) {
    .team-grid { grid-template-columns: 1fr; gap: var(--sp-8); }
    .team-bio { max-width: none; }
  }
</style>
