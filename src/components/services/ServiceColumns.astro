---
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;

const services = [
  {
    acronym: 'AMO',
    titleKey: 'services.amo.title' as const,
    body: lang === 'fr'
      ? 'Accompagnement du maître d\'ouvrage à chaque phase — de la définition du programme jusqu\'à la livraison de l\'ouvrage. Vérification des engagements contractuels, suivi Qualité–Coût–Délai.'
      : 'Supporting the project owner at every phase — from programme definition through to handover. Verification of contractual commitments, Quality–Cost–Schedule monitoring.',
  },
  {
    acronym: 'MOD',
    titleKey: 'services.mod.title' as const,
    body: lang === 'fr'
      ? 'Délégation complète des attributions du maître d\'ouvrage : pilotage de la maîtrise d\'œuvre, gestion administrative et contractuelle, suivi financier et coordination des intervenants.'
      : 'Full delegation of project owner responsibilities: project management, administrative and contractual management, financial monitoring and stakeholder coordination.',
  },
  {
    acronym: 'Conseil',
    titleKey: 'services.conseil.title' as const,
    body: lang === 'fr'
      ? 'Audit d\'acquisition, due diligence technique, analyse de valeur, optimisation de capacité. Un regard d\'expert à toute phase pour sécuriser vos décisions immobilières.'
      : 'Acquisition audit, technical due diligence, value analysis, capacity optimisation. Expert insight at any phase to secure your real estate decisions.',
  },
] as const;
---

<section class="service-cols section">
  <div class="page-wrap">
    <div class="cols-grid reveal-group">
      {services.map(({ acronym, titleKey, body }) => (
        <article class="service-card reveal">
          <div class="card-top-line" aria-hidden="true"></div>
          <span class="service-acronym">{acronym}</span>
          <h3 class="service-name">{t(lang, titleKey)}</h3>
          <p class="service-body">{body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .cols-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-6);
  }

  .service-card {
    padding: var(--sp-8) var(--sp-6);
    border: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
    cursor: default;
  }

  /* Top gold border that expands on hover */
  .card-top-line {
    position: absolute;
    top: -1px;
    left: 0;
    height: 2px;
    width: 0;
    background: var(--color-gold);
    transition: width 400ms var(--ease-out);
  }

  .service-card:hover .card-top-line {
    width: 100%;
  }

  .service-acronym {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(3rem, 5vw, 4.5rem);
    font-weight: 300;
    line-height: 1;
    color: var(--color-gold);
    margin-bottom: var(--sp-3);
    letter-spacing: -0.03em;
    transition: transform var(--duration-base) var(--ease-out);
  }

  .service-card:hover .service-acronym {
    transform: translateY(-2px);
  }

  .service-name {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--sp-4);
    line-height: 1.5;
  }

  .service-body {
    font-size: var(--text-base);
    font-weight: 300;
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
    max-width: 36ch;
  }

  @media (prefers-reduced-motion: reduce) {
    .card-top-line, .service-acronym, .reveal {
      transition: none !important;
      width: auto !important;
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }

  @media (max-width: 860px) {
    .cols-grid { grid-template-columns: 1fr; }
    .service-body { max-width: none; }
  }
</style>
