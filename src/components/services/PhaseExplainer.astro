---
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;

const phases = [
  {
    num: '01',
    titleKey: 'services.phase.prog' as const,
    items: lang === 'fr'
      ? ['Définition du programme', 'Sélection de l\'architecte', 'Constitution de l\'équipe MOE', 'Contrôle budget & planning', 'Guidance administrative et juridique']
      : ['Programme definition', 'Architect selection', 'Design team assembly', 'Budget & schedule control', 'Administrative & legal guidance'],
  },
  {
    num: '02',
    titleKey: 'services.phase.conc' as const,
    items: lang === 'fr'
      ? ['Supervision de la conception', 'Vérification des documents', 'Procédures administratives', 'Pilotage de l\'appel d\'offres', 'Finalisation des contrats']
      : ['Design supervision', 'Document verification', 'Administrative procedures', 'Tender process management', 'Contract finalisation'],
  },
  {
    num: '03',
    titleKey: 'services.phase.real' as const,
    items: lang === 'fr'
      ? ['Suivi de la réalisation', 'Conformité Qualité–Coût–Délai', 'Coordination des entreprises', 'Suivi de la livraison', 'Gestion des réserves et du parfait achèvement']
      : ['Construction monitoring', 'Quality–Cost–Schedule compliance', 'Contractor coordination', 'Handover tracking', 'Defects & snagging management'],
  },
];
---

<section class="phase-explainer section" style="background: var(--color-bg-alt);">
  <div class="page-wrap">
    <span class="section-label reveal">
      {lang === 'fr' ? 'Les phases d\'intervention' : 'Phases of involvement'}
    </span>

    <!-- Desktop timeline -->
    <div class="timeline reveal" aria-label={lang === 'fr' ? 'Phases' : 'Phases'}>
      <!-- SVG connector line -->
      <svg class="timeline-svg" aria-hidden="true" viewBox="0 0 100 8" preserveAspectRatio="none">
        <line x1="16.5" y1="4" x2="83.5" y2="4" stroke="var(--color-gold)" stroke-width="0.5" stroke-dasharray="3 3"/>
        <!-- Arrowheads at phase transitions -->
        <polygon points="33,1.5 36.5,4 33,6.5" fill="var(--color-gold)" opacity="0.6"/>
        <polygon points="63,1.5 66.5,4 63,6.5" fill="var(--color-gold)" opacity="0.6"/>
      </svg>

      <div class="phases-row reveal-group">
        {phases.map(({ num, titleKey, items }, i) => (
          <article class="phase reveal">
            <div class="phase-number" aria-hidden="true">
              <svg viewBox="0 0 48 48" fill="none" class="phase-circle">
                <circle cx="24" cy="24" r="22" stroke="var(--color-gold)" stroke-width="1"/>
                <text x="24" y="29" text-anchor="middle"
                  font-family="'Cormorant','Cormorant Garamond',Georgia,serif"
                  font-size="15" font-weight="400" fill="var(--color-gold)">{num}</text>
              </svg>
            </div>
            <h3 class="phase-title">{t(lang, titleKey)}</h3>
            <ul class="phase-list" role="list">
              {items.map(item => (
                <li class="phase-item">{item}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>

    <!-- Mobile accordion -->
    <div class="phases-accordion" id="phases-accordion">
      {phases.map(({ num, titleKey, items }, i) => (
        <details class="accordion-item" open={i === 0}>
          <summary class="accordion-summary">
            <span class="acc-num mono">{num}</span>
            <span class="acc-title">{t(lang, titleKey)}</span>
            <svg class="acc-chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
            </svg>
          </summary>
          <ul class="accordion-list" role="list">
            {items.map(item => (
              <li class="phase-item">{item}</li>
            ))}
          </ul>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline { position: relative; }

  .timeline-svg {
    position: absolute;
    top: 24px;
    left: 0;
    right: 0;
    width: 100%;
    height: 8px;
    z-index: 0;
  }

  .phases-row {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-8);
  }

  .phase { display: flex; flex-direction: column; gap: var(--sp-4); }

  .phase-circle { width: 48px; height: 48px; }

  .phase-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 400;
    color: var(--color-void);
  }

  .phase-list { display: flex; flex-direction: column; gap: var(--sp-2); }

  .phase-item {
    font-size: var(--text-base);
    font-weight: 300;
    color: var(--color-text-muted);
    padding-left: var(--sp-3);
    border-left: 2px solid var(--color-gold-dim);
    line-height: var(--leading-normal);
    transition: border-color var(--duration-fast) ease;
  }

  .phase-item:hover { border-left-color: var(--color-gold); }

  /* Mobile accordion — hidden on desktop */
  .phases-accordion { display: none; }

  .accordion-item {
    border-bottom: 1px solid var(--color-border);
  }

  .accordion-item:first-child { border-top: 1px solid var(--color-border); }

  .accordion-summary {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding-block: var(--sp-4);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .accordion-summary::-webkit-details-marker { display: none; }

  .acc-num {
    color: var(--color-gold);
    font-size: var(--text-sm);
    flex-shrink: 0;
  }

  .acc-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 400;
    flex: 1;
  }

  .acc-chevron {
    width: 16px;
    height: 16px;
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: transform var(--duration-base) ease;
  }

  details[open] .acc-chevron { transform: rotate(180deg); }

  .accordion-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding-bottom: var(--sp-4);
    padding-left: var(--sp-8);
  }

  @media (prefers-reduced-motion: reduce) {
    .acc-chevron, .phase-item, .reveal {
      transition: none !important;
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }

  @media (max-width: 860px) {
    .timeline, .phases-row { display: none; }
    .phases-accordion { display: block; }
  }
</style>
