---
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const refsHref = lang === 'fr' ? '/fr/references' : '/en/references';
---

<section class="hero" aria-label="Introduction">
  <!-- Grain texture overlay -->
  <svg class="grain" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    <filter id="hero-grain">
      <feTurbulence type="fractalNoise" baseFrequency="0.72" numOctaves="4" stitchTiles="stitch"/>
      <feColorMatrix type="saturate" values="0"/>
    </filter>
    <rect width="100%" height="100%" filter="url(#hero-grain)"/>
  </svg>

  <div class="hero-inner page-wrap">
    <div class="hero-content">
      <!-- Eyebrow label -->
      <span class="hero-line hero-eyebrow label">
        {lang === 'fr' ? 'Conseil · Immobilier · Tertiaire' : 'Advisory · Real Estate · Commercial'}
      </span>

      <!-- Main headline — split across lines for stagger -->
      <h1 class="hero-headline" aria-label={lang === 'fr' ? 'Maîtrise d\'Ouvrage au plus haut niveau.' : 'Project Management at the highest level.'}>
        <span class="hero-line hero-line--1">
          {lang === 'fr' ? 'Maîtrise' : 'Project'}
        </span>
        <span class="hero-line hero-line--2">
          {lang === 'fr' ? "d\u2019Ouvrage" : 'Management'}
        </span>
        <span class="hero-line hero-line--3 hero-line--italic">
          {lang === 'fr' ? 'au plus haut' : 'at the highest'}
        </span>
        <span class="hero-line hero-line--4">
          {lang === 'fr' ? 'niveau.' : 'level.'}
        </span>
      </h1>

      <!-- Gold hairline -->
      <div class="hero-rule hero-accent-line" aria-hidden="true"></div>

      <!-- Subtitle + CTA row -->
      <div class="hero-footer hero-line hero-line--5">
        <p class="hero-sub">{t(lang, 'hero.sub')}</p>
        <a href={refsHref} class="hero-cta">
          <span>{t(lang, 'hero.cta')}</span>
          <svg width="16" height="10" viewBox="0 0 16 10" fill="none" aria-hidden="true">
            <path d="M1 5h14M10 1l5 4-5 4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Large background numeral — decorative -->
    <span class="hero-bg-numeral" aria-hidden="true">N</span>
  </div>

  <!-- Bottom scroll indicator -->
  <div class="hero-scroll hero-line hero-line--6" aria-hidden="true">
    <span class="mono">Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    background-color: var(--color-stone);
    overflow: hidden;
  }

  /* Grain */
  .grain {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0.045;
    z-index: 0;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    flex: 1;
    display: flex;
    align-items: center;
    padding-top: calc(68px + var(--sp-12));
    padding-bottom: var(--sp-16);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
    max-width: 1000px;
  }

  /* Eyebrow */
  .hero-eyebrow {
    color: var(--color-gold);
    letter-spacing: var(--tracking-widest);
  }

  /* Headline — oversized per Exaggerated Minimalism direction */
  .hero-headline {
    display: flex;
    flex-direction: column;
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 8.5vw, 9.5rem);
    font-weight: 300;
    line-height: 0.95;
    letter-spacing: -0.025em;
    color: var(--color-void);
    margin: 0;
  }

  .hero-line--italic {
    font-style: italic;
    color: var(--color-ash);
  }

  .hero-line--4 {
    color: var(--color-void);
  }

  /* Animated gold hairline */
  .hero-rule {
    width: 56px;
    height: 1.5px;
    background: var(--color-gold);
    transform-origin: left center;
  }

  /* Footer row */
  .hero-footer {
    display: flex;
    align-items: center;
    gap: var(--sp-8);
    flex-wrap: wrap;
  }

  .hero-sub {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-muted);
    max-width: none;
    margin: 0;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-void);
    border-bottom: 1px solid var(--color-gold);
    padding-bottom: 3px;
    transition: color var(--duration-base) ease, gap var(--duration-base) var(--ease-out);
    cursor: pointer;
  }

  .hero-cta:hover {
    color: var(--color-gold);
    gap: var(--sp-3);
  }

  .hero-cta:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 4px;
  }

  /* Background decorative letter */
  .hero-bg-numeral {
    position: absolute;
    right: -0.05em;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-display);
    font-size: clamp(18rem, 30vw, 38rem);
    font-weight: 300;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(184, 154, 106, 0.08);
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  /* Scroll indicator */
  .hero-scroll {
    position: absolute;
    bottom: var(--sp-6);
    left: var(--page-padding);
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    z-index: 1;
  }

  .hero-scroll span {
    font-size: 10px;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
  }

  .scroll-line {
    width: 32px;
    height: 1px;
    background: var(--color-gold);
    animation: scrollPulse 2s ease-in-out infinite;
    transform-origin: left;
  }

  @keyframes scrollPulse {
    0%, 100% { transform: scaleX(1); opacity: 1; }
    50% { transform: scaleX(0.4); opacity: 0.4; }
  }

  /* Stagger overrides for hero lines */
  .hero-line--1 { animation-delay: 60ms; }
  .hero-line--2 { animation-delay: 160ms; }
  .hero-line--3 { animation-delay: 260ms; }
  .hero-line--4 { animation-delay: 360ms; }
  .hero-line--5 { animation-delay: 500ms; }
  .hero-line--6 { animation-delay: 700ms; }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-line,
    .hero-accent-line,
    .scroll-line {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }

  @media (max-width: 640px) {
    .hero-headline {
      font-size: clamp(3rem, 13vw, 5rem);
    }
    .hero-footer {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--sp-4);
    }
    .hero-bg-numeral { display: none; }
  }
</style>
