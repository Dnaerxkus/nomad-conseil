---
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/ui';
import { getCollection } from 'astro:content';
import { asset } from '../../utils/asset';

interface Props { lang: Lang; }
const { lang } = Astro.props;

const all = await getCollection('projects');
const featured = all
  .filter(p => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const refsHref = link(lang === 'fr' ? '/fr/references' : '/en/references');
---

<section class="refs-teaser section">
  <div class="page-wrap refs-header reveal">
    <span class="section-label">{t(lang, 'section.references')}</span>
    <a href={refsHref} class="refs-all-link" aria-label={t(lang, 'ref.all')}>
      {t(lang, 'ref.all')} →
    </a>
  </div>

  <div class="refs-scroll-wrap">
    <ul class="refs-row page-wrap reveal-group" role="list">
      {featured.map((project) => (
        <li class="ref-card reveal" role="listitem">
          <a href={refsHref} class="ref-card-link" aria-label={project.data.title}>
            <!-- Image / Placeholder -->
            <div class="ref-img-wrap">
              {project.data.image ? (
                <img
                  src={asset(project.data.image)}
                  alt={project.data.title}
                  loading="lazy"
                  class="ref-img"
                />
              ) : (
                <div class="ref-img-placeholder" aria-hidden="true">
                  <span class="placeholder-initial">
                    {project.data.title.charAt(0)}
                  </span>
                </div>
              )}
              <!-- Hover overlay -->
              <div class="ref-overlay" aria-hidden="true">
                <span class="tag">{project.data.mission}</span>
                {project.data.surface && (
                  <span class="ref-surface mono">{project.data.surface}</span>
                )}
              </div>
            </div>

            <!-- Card meta -->
            <div class="ref-meta">
              <h3 class="ref-title">{project.data.title}</h3>
              <p class="ref-sub">
                <span>{project.data.city}</span>
                <span class="ref-sep" aria-hidden="true">·</span>
                <span>{project.data.client}</span>
              </p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .refs-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--sp-6);
    gap: var(--sp-4);
  }

  .refs-header .section-label {
    margin-bottom: 0;
  }

  .refs-all-link {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-gold);
    transition: opacity var(--duration-fast) ease, letter-spacing var(--duration-base) var(--ease-out);
    cursor: pointer;
    white-space: nowrap;
  }

  .refs-all-link:hover { opacity: 0.7; letter-spacing: 0.1em; }
  .refs-all-link:focus-visible { outline: 2px solid var(--color-gold); outline-offset: 4px; }

  /* Horizontal scroll on mobile */
  .refs-scroll-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .refs-scroll-wrap::-webkit-scrollbar { display: none; }

  .refs-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-4);
    min-width: 860px;
  }

  /* Card */
  .ref-card-link {
    display: block;
    cursor: pointer;
  }

  .ref-card-link:focus-visible { outline: 2px solid var(--color-gold); outline-offset: 4px; }

  .ref-img-wrap {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--color-bg-alt);
    margin-bottom: var(--sp-3);
  }

  .ref-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .ref-card-link:hover .ref-img {
    transform: scale(1.04);
  }

  /* Placeholder gradient */
  .ref-img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(
      135deg,
      #e8e2da 0%,
      #d4ccc2 35%,
      #c4bbb0 65%,
      #b8b0a5 100%
    );
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder-initial {
    font-family: var(--font-display);
    font-size: clamp(4rem, 8vw, 8rem);
    font-weight: 300;
    color: rgba(15, 15, 13, 0.12);
    line-height: 1;
    user-select: none;
  }

  /* Hover overlay */
  .ref-overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 15, 13, 0.72);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    opacity: 0;
    transition: opacity var(--duration-base) ease;
  }

  .ref-card-link:hover .ref-overlay,
  .ref-card-link:focus-visible .ref-overlay {
    opacity: 1;
  }

  .ref-surface {
    color: var(--color-chalk);
    font-size: var(--text-sm);
  }

  /* Meta below image */
  .ref-meta { padding-top: var(--sp-1); }

  .ref-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--color-void);
    line-height: var(--leading-tight);
    margin-bottom: 4px;
    transition: color var(--duration-fast) ease;
  }

  .ref-card-link:hover .ref-title { color: var(--color-gold); }

  .ref-sub {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 300;
    color: var(--color-text-muted);
    max-width: none;
    margin: 0;
  }

  .ref-sep { color: var(--color-gold); opacity: 0.5; }

  @media (prefers-reduced-motion: reduce) {
    .ref-img, .ref-overlay, .reveal { transition: none !important; animation: none !important; opacity: 1 !important; transform: none !important; }
  }

  @media (max-width: 860px) {
    .refs-row { min-width: calc(2.2 * (70vw + var(--sp-4))); grid-template-columns: repeat(4, 70vw); }
  }
</style>
