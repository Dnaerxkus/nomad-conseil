---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';

const lang = 'fr';
---

<PageLayout
  lang={lang}
  title="Contact"
  description="Contactez Nomad Conseil pour discuter de votre projet immobilier."
  alternatePath="/contact"
>
  <PageHeader
    lang={lang}
    label="Nous contacter"
    title="Contact"
    sub="Réponse sous 48h"
  />

  <section class="section">
    <div class="page-wrap contact-grid">

      <!-- Form -->
      <div class="contact-form-wrap">
        <form class="contact-form" action="mailto:contact@nomad-conseil.fr" method="POST" enctype="text/plain">
          <div class="field-row">
            <div class="field">
              <label for="societe">Société</label>
              <input type="text" id="societe" name="Société" autocomplete="organization" />
            </div>
            <div class="field">
              <label for="fonction">Fonction</label>
              <input type="text" id="fonction" name="Fonction" autocomplete="organization-title" />
            </div>
          </div>
          <div class="field">
            <label for="nom">Nom <span class="req">*</span></label>
            <input type="text" id="nom" name="Nom" required autocomplete="name" />
          </div>
          <div class="field">
            <label for="email">Email <span class="req">*</span></label>
            <input type="email" id="email" name="Email" required autocomplete="email" />
          </div>
          <div class="field">
            <label for="objet">Objet <span class="req">*</span></label>
            <input type="text" id="objet" name="Objet" required />
          </div>
          <div class="field">
            <label for="message">Message <span class="req">*</span></label>
            <textarea id="message" name="Message" rows="6" required></textarea>
          </div>
          <p class="req-note"><span class="req">*</span> Champs obligatoires</p>
          <button type="submit" class="submit-btn">Envoyer le message</button>
        </form>
      </div>

      <!-- Info panel -->
      <aside class="contact-info">
        <div class="info-block">
          <span class="section-label">Email</span>
          <a href="mailto:contact@nomad-conseil.fr" class="contact-email">contact@nomad-conseil.fr</a>
        </div>
        <div class="info-block">
          <span class="section-label">Adresse</span>
          <p>Paris, France</p>
        </div>
        <div class="info-block">
          <p class="reply-note"><em>Réponse sous 48h</em></p>
        </div>
      </aside>
    </div>
  </section>
</PageLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--sp-16);
    align-items: start;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-4);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  input, textarea {
    width: 100%;
    border: none;
    border-bottom: 1px solid var(--color-border);
    background: transparent;
    padding: var(--sp-2) 0;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 300;
    color: var(--color-text);
    transition: border-color var(--duration-base) ease;
    outline: none;
    border-radius: 0;
  }

  input:focus, textarea:focus {
    border-bottom-color: var(--color-gold);
  }

  textarea { resize: vertical; min-height: 140px; }

  .req { color: var(--color-gold); }
  .req-note { font-size: var(--text-xs); color: var(--color-text-muted); }

  .submit-btn {
    width: 100%;
    background: var(--color-void);
    color: var(--color-stone);
    padding: var(--sp-3) var(--sp-4);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    transition: background var(--duration-base) ease, color var(--duration-base) ease;
    margin-top: var(--sp-2);
  }

  .submit-btn:hover {
    background: var(--color-gold);
    color: var(--color-void);
  }

  /* Info panel */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--sp-8);
    padding-top: var(--sp-2);
  }

  .info-block { display: flex; flex-direction: column; gap: var(--sp-1); }

  .contact-email {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-gold);
    transition: opacity var(--duration-fast) ease;
  }

  .contact-email:hover { opacity: 0.7; }

  .reply-note {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 300;
    color: var(--color-text-muted);
    max-width: none;
  }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; }
    .field-row { grid-template-columns: 1fr; }
    .contact-info { order: -1; }
  }
</style>
