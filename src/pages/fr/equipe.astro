---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import TeamCard from '../../components/team/TeamCard.astro';
import CtaBand from '../../components/ui/CtaBand.astro';

const lang = 'fr';
---

<PageLayout
  lang={lang}
  title="Équipe"
  description="L'équipe Nomad Conseil — des experts en maîtrise d'ouvrage au service de vos projets immobiliers."
  alternatePath="/team"
>
  <PageHeader
    lang={lang}
    label="L'équipe"
    title="L'Équipe"
    sub="Des experts au service de vos projets."
  />
  <TeamCard lang={lang} />
  <CtaBand lang={lang} />
</PageLayout>
